# Figma API Configuration
# Get your token from: https://www.figma.com/developers/api#access-tokens

# Personal Access Token from Figma
FIGMA_TOKEN=your_figma_personal_access_token_here

# File key from your Figma file URL
# Example URL: https://www.figma.com/design/ABC123XYZ/My-Design
# File key would be: ABC123XYZ
FIGMA_FILE_KEY=your_figma_file_key_here

# Full Figma file URL (optional, used by some scripts)
FIGMA_FILE_URL=https://www.figma.com/design/YOUR_FILE_KEY/Your-File-Name?node-id=0-1
