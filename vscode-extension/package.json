{
  "name": "code-to-figma-vscode",
  "displayName": "Code to Figma",
  "description": "Convert UI components to Figma designs seamlessly with one-click server management",
  "version": "1.0.0",
  "publisher": "code-to-figma",
  "license": "MIT",
  "icon": "resources/icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/code-to-figma.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/code-to-figma/issues"
  },
  "homepage": "https://github.com/yourusername/code-to-figma#readme",
  "keywords": [
    "figma",
    "design",
    "react",
    "vue",
    "html",
    "component",
    "export",
    "sync",
    "server",
    "bridge"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeToFigma.startServer",
        "title": "Start Bridge Server",
        "category": "Code to Figma",
        "icon": "$(play-circle)"
      },
      {
        "command": "codeToFigma.stopServer",
        "title": "Stop Bridge Server",
        "category": "Code to Figma",
        "icon": "$(stop-circle)"
      },
      {
        "command": "codeToFigma.restartServer",
        "title": "Restart Bridge Server",
        "category": "Code to Figma",
        "icon": "$(refresh)"
      },
      {
        "command": "codeToFigma.testConnection",
        "title": "Test Connection",
        "category": "Code to Figma",
        "icon": "$(heart)"
      },
      {
        "command": "codeToFigma.clearLogs",
        "title": "Clear Logs",
        "category": "Code to Figma",
        "icon": "$(clear-all)"
      },
      {
        "command": "codeToFigma.convertToJSON",
        "title": "Convert Component to JSON",
        "category": "Code to Figma"
      },
      {
        "command": "codeToFigma.exportToFigma",
        "title": "Export to Figma",
        "category": "Code to Figma",
        "icon": "$(export)"
      },
      {
        "command": "codeToFigma.syncWithFigma",
        "title": "Sync with Figma",
        "category": "Code to Figma"
      },
      {
        "command": "codeToFigma.autoSync",
        "title": "Toggle Auto-Sync",
        "category": "Code to Figma"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "codeToFigma.startServer"
        },
        {
          "command": "codeToFigma.stopServer"
        },
        {
          "command": "codeToFigma.restartServer"
        },
        {
          "command": "codeToFigma.testConnection"
        },
        {
          "command": "codeToFigma.clearLogs"
        }
      ],
      "editor/context": [
        {
          "command": "codeToFigma.convertToJSON",
          "group": "codeToFigma@1",
          "when": "editorTextFocus"
        },
        {
          "command": "codeToFigma.exportToFigma",
          "group": "codeToFigma@2",
          "when": "editorTextFocus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codeToFigma.exportToFigma",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e"
      },
      {
        "command": "codeToFigma.restartServer",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "Code to Figma",
      "properties": {
        "codeToFigma.figmaFileId": {
          "type": "string",
          "default": "",
          "description": "Your Figma file ID"
        },
        "codeToFigma.figmaAccessToken": {
          "type": "string",
          "default": "",
          "description": "Your Figma personal access token"
        },
        "codeToFigma.autoSync": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync changes with Figma on save"
        },
        "codeToFigma.autoStartServer": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start bridge server when VS Code starts"
        },
        "codeToFigma.outputFolder": {
          "type": "string",
          "default": "./figma-exports",
          "description": "Folder to save generated JSON files"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeToFigma",
          "title": "Code to Figma",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "codeToFigma": [
        {
          "id": "codeToFigmaServer",
          "name": "Server & Logs",
          "icon": "$(server-process)"
        },
        {
          "id": "codeToFigmaComponents",
          "name": "Components",
          "icon": "$(symbol-class)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codeToFigmaServer",
        "contents": "Welcome to Code to Figma!\n\n[Start Bridge Server](command:codeToFigma.startServer)\n\nStart the bridge server to enable communication between VS Code and Figma.\n\n[Test Connection](command:codeToFigma.testConnection)\n\nTest the connection to ensure everything is working properly."
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "bridge:start": "node figma-bridge-server.js",
    "package": "vsce package",
    "icon:generate": "node generate-icon.js"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "axios": "^1.6.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.18.0"
  }
}
